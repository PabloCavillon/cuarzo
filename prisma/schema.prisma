generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Lead {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  business  String?
  service   Service
  message   String?
  createdAt DateTime @default(now())
}

enum Service {
  WEB
  BRAND
  BOTH
}
