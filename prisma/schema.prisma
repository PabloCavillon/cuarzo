// Cuarzo — multi-tenant platform schema
// Modules: Core · Turnera · Catalog · Stock · Orders · Payments · Fiscal · Caja · CRM
//
// Design principles:
//   - Every domain table carries tenantId (row-level multi-tenancy)
//   - Snapshot fields on items/bookings preserve historical accuracy
//   - StockMovement is an append-only ledger (no FKs to product — survives deletions)
//   - Payments and Orders are module-independent so Fiscal can reference either

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────────

enum TenantPlan {
  free
  starter
  pro
  enterprise
}

enum UserRole {
  owner
  admin
  staff
}

enum ModuleSlug {
  turnera
  catalog
  stock
  orders
  payments
  fiscal
  caja
}

enum CajaTipo {
  ingreso
  egreso
}

enum BookingStatus {
  confirmed
  cancelled
  no_show
}

enum OrderStatus {
  draft
  confirmed
  processing
  shipped
  delivered
  cancelled
  refunded
}

enum PaymentStatus {
  pending
  processing
  completed
  failed
  refunded
}

enum PaymentMethod {
  mercadopago
  transferencia
  efectivo
  stripe
}

enum StockMovementReason {
  sale
  purchase
  return_customer
  return_supplier
  adjustment
  damage
  initial
}

enum SubscriptionStatus {
  pending
  authorized
  paused
  cancelled
  expired
}

enum TipoComprobante {
  A
  B
  C
  M
  X
}

enum TaskStatus {
  pending
  in_progress
  done
  cancelled
}

enum TaskPriority {
  low
  medium
  high
  urgent
}

enum TaskRecurrence {
  none
  daily
  weekly
  monthly
  yearly
}

// ─────────────────────────────────────────────────────────────────────────────
// CORE — Tenants, Modules, Users
// ─────────────────────────────────────────────────────────────────────────────

model Tenant {
  id        String     @id @default(uuid())
  name      String
  slug      String     @unique
  plan      TenantPlan @default(free)
  active    Boolean    @default(true)
  onboarded Boolean    @default(false)
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  modules        TenantModule[]
  users          User[]
  turneraServices TurneraService[]
  turneraBookings TurneraBooking[]
  categories     CatalogCategory[]
  products       CatalogProduct[]
  warehouses     StockWarehouse[]
  stockItems     StockItem[]
  stockMovements StockMovement[]
  orderClients   OrderClient[]
  orders         Order[]
  payments       Payment[]
  fiscalConfig   FiscalConfig?
  fiscalInvoices FiscalInvoice[]
  clients            Client[]
  suppliers          Supplier[]
  cajaMovimientos    CajaMovimiento[]
  subscription       Subscription?
  invitations        Invitation[]
  auditLogs          AuditLog[]
  tasks              Task[]
  pushSubscriptions  PushSubscription[]

  @@map("tenants")
}

model Invitation {
  id         String    @id @default(uuid())
  tenantId   String    @map("tenant_id")
  email      String
  role       UserRole  @default(staff)
  token      String    @unique @default(uuid())
  expiresAt  DateTime  @map("expires_at")
  acceptedAt DateTime? @map("accepted_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, email])
  @@index([token])
  @@map("invitations")
}

model TenantModule {
  id        String     @id @default(uuid())
  tenantId  String     @map("tenant_id")
  module    ModuleSlug
  active    Boolean    @default(true)
  config    Json       @default("{}")
  enabledAt DateTime   @default(now()) @map("enabled_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, module])
  @@index([tenantId])
  @@map("tenant_modules")
}

model User {
  id            String    @id @default(uuid())
  tenantId      String    @map("tenant_id")
  email         String
  name          String
  role          UserRole  @default(staff)
  active        Boolean   @default(true)
  superAdmin    Boolean   @default(false) @map("super_admin")
  // Auth fields — password is null for OAuth-only users
  password      String?
  image         String?
  googleId      String?   @unique @map("google_id")
  emailVerified DateTime? @map("email_verified")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tasksCreated      Task[]             @relation("TaskCreator")
  tasksAssigned     Task[]             @relation("TaskAssignee")
  pushSubscriptions PushSubscription[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

// ─────────────────────────────────────────────────────────────────────────────
// MODULE: TURNERA
// ─────────────────────────────────────────────────────────────────────────────

model TurneraService {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  name        String
  description String?
  durationMin Int      @map("duration_min")
  price       Decimal  @default(0) @db.Decimal(14, 2)
  active      Boolean  @default(true)
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant   Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bookings TurneraBooking[]

  @@index([tenantId, active])
  @@map("turnera_services")
}

model TurneraBooking {
  id        String @id @default(uuid())
  tenantId  String @map("tenant_id")
  serviceId String @map("service_id")
  code      String @unique

  // Snapshots — preserve the service state at booking time
  serviceNameSnap String  @map("service_name_snap")
  durationMinSnap Int     @map("duration_min_snap")
  priceSnap       Decimal @default(0) @map("price_snap") @db.Decimal(14, 2)

  date   String        // YYYY-MM-DD
  time   String        // HH:MM
  status BookingStatus @default(confirmed)

  clientName  String  @map("client_name")
  clientEmail String  @map("client_email")
  clientPhone String? @map("client_phone")
  notes       String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant  Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  service TurneraService @relation(fields: [serviceId], references: [id])

  @@index([tenantId])
  @@index([tenantId, clientEmail])
  @@index([tenantId, date])
  @@map("turnera_bookings")
}

// ─────────────────────────────────────────────────────────────────────────────
// MODULE: CATALOG  (shared foundation for Stock, Orders, E-commerce)
// ─────────────────────────────────────────────────────────────────────────────

model CatalogCategory {
  id       String  @id @default(uuid())
  tenantId String  @map("tenant_id")
  name     String
  parentId String? @map("parent_id")

  tenant   Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent   CatalogCategory?  @relation("CategoryTree", fields: [parentId], references: [id])
  children CatalogCategory[] @relation("CategoryTree")
  products CatalogProduct[]

  @@index([tenantId])
  @@map("catalog_categories")
}

model CatalogProduct {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  categoryId  String?  @map("category_id")
  sku         String
  name        String
  description String?
  basePrice   Decimal  @map("base_price") @db.Decimal(14, 2)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant     Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category   CatalogCategory?       @relation(fields: [categoryId], references: [id])
  variants   CatalogProductVariant[]
  stockItems StockItem[]
  orderItems OrderItem[]

  @@unique([tenantId, sku])
  @@index([tenantId, active])
  @@map("catalog_products")
}

model CatalogProductVariant {
  id         String  @id @default(uuid())
  productId  String  @map("product_id")
  name       String
  sku        String
  priceDelta Decimal @default(0) @map("price_delta") @db.Decimal(14, 2)
  active     Boolean @default(true)

  product    CatalogProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  stockItems StockItem[]
  orderItems OrderItem[]

  @@unique([productId, sku])
  @@index([productId])
  @@map("catalog_product_variants")
}

// ─────────────────────────────────────────────────────────────────────────────
// MODULE: STOCK
// ─────────────────────────────────────────────────────────────────────────────

model StockWarehouse {
  id       String  @id @default(uuid())
  tenantId String  @map("tenant_id")
  name     String
  address  String?
  active   Boolean @default(true)

  tenant     Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  stockItems StockItem[]
  movements  StockMovement[]

  @@index([tenantId])
  @@map("stock_warehouses")
}

// Current quantity per product/variant/warehouse — maintained by triggers or app logic
model StockItem {
  id          String  @id @default(uuid())
  tenantId    String  @map("tenant_id")
  productId   String  @map("product_id")
  variantId   String? @map("variant_id")
  warehouseId String  @map("warehouse_id")
  qty         Int     @default(0)
  minStock    Int     @default(0) @map("min_stock")

  tenant    Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product   CatalogProduct         @relation(fields: [productId], references: [id])
  variant   CatalogProductVariant? @relation(fields: [variantId], references: [id])
  warehouse StockWarehouse         @relation(fields: [warehouseId], references: [id])

  @@unique([productId, variantId, warehouseId])
  @@index([tenantId])
  @@map("stock_items")
}

// Append-only ledger — productId/variantId are plain strings (no FK) so
// history is preserved even if the product is later deleted.
model StockMovement {
  id            String              @id @default(uuid())
  tenantId      String              @map("tenant_id")
  productId     String              @map("product_id")
  variantId     String?             @map("variant_id")
  warehouseId   String              @map("warehouse_id")
  delta         Int
  reason        StockMovementReason
  referenceId   String?             @map("reference_id")   // e.g. orderId
  referenceType String?             @map("reference_type") // e.g. "order"
  notes         String?
  createdAt     DateTime            @default(now()) @map("created_at")

  tenant    Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  warehouse StockWarehouse @relation(fields: [warehouseId], references: [id])

  @@index([tenantId, createdAt])
  @@index([tenantId, productId])
  @@map("stock_movements")
}

// ─────────────────────────────────────────────────────────────────────────────
// MODULE: ORDERS  (shared with E-commerce)
// ─────────────────────────────────────────────────────────────────────────────

model OrderClient {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  email     String
  name      String
  phone     String?
  address   String?
  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orders Order[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("order_clients")
}

model Order {
  id        String      @id @default(uuid())
  tenantId  String      @map("tenant_id")
  clientId  String      @map("client_id")
  status    OrderStatus @default(draft)
  subtotal  Decimal     @db.Decimal(14, 2)
  discount  Decimal     @default(0) @db.Decimal(14, 2)
  tax       Decimal     @default(0) @db.Decimal(14, 2)
  total     Decimal     @db.Decimal(14, 2)
  notes     String?
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  tenant   Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client   OrderClient    @relation(fields: [clientId], references: [id])
  items    OrderItem[]
  payments Payment[]
  invoices FiscalInvoice[]

  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@map("orders")
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String  @map("order_id")
  productId String  @map("product_id")
  variantId String? @map("variant_id")

  // Snapshots — preserve price and name at the moment the order was placed
  skuSnap   String  @map("sku_snap")
  nameSnap  String  @map("name_snap")
  qty       Int
  unitPrice Decimal @map("unit_price") @db.Decimal(14, 2)

  order   Order                  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product CatalogProduct         @relation(fields: [productId], references: [id])
  variant CatalogProductVariant? @relation(fields: [variantId], references: [id])

  @@index([orderId])
  @@map("order_items")
}

// ─────────────────────────────────────────────────────────────────────────────
// MODULE: PAYMENTS
// ─────────────────────────────────────────────────────────────────────────────

model Payment {
  id          String        @id @default(uuid())
  tenantId    String        @map("tenant_id")
  orderId     String?       @map("order_id")
  amount      Decimal       @db.Decimal(14, 2)
  currency    String        @default("ARS")
  method      PaymentMethod
  externalRef String?       @map("external_ref")
  status      PaymentStatus @default(pending)
  metadata    Json          @default("{}")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  tenant   Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  order    Order?         @relation(fields: [orderId], references: [id])
  invoices FiscalInvoice[]

  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@map("payments")
}

// ─────────────────────────────────────────────────────────────────────────────
// MODULE: FISCAL / ARCA (AFIP)
// ─────────────────────────────────────────────────────────────────────────────

model FiscalConfig {
  id           String    @id @default(uuid())
  tenantId     String    @unique @map("tenant_id")
  cuit         String
  ivaCondition String    @map("iva_condition")
  puntoVenta   Int       @map("punto_venta")
  afipCert     String?   @map("afip_cert")
  afipKey      String?   @map("afip_key")
  production   Boolean   @default(false)
  taToken      String?   @map("ta_token")
  taSign       String?   @map("ta_sign")
  taExpiration DateTime? @map("ta_expiration")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("fiscal_configs")
}

model FiscalInvoice {
  id               String          @id @default(uuid())
  tenantId         String          @map("tenant_id")
  orderId          String?         @map("order_id")
  paymentId        String?         @map("payment_id")
  tipoComprobante  TipoComprobante @map("tipo_comprobante")
  puntoVenta       Int             @default(1) @map("punto_venta")
  numero           Int
  fecha            String          @default("")
  concepto         Int             @default(1)
  receptorDocTipo  Int             @default(99) @map("receptor_doc_tipo")
  receptorDocNro   String          @default("0") @map("receptor_doc_nro")
  receptorNombre   String?         @map("receptor_nombre")
  cae              String
  caeVto           DateTime        @map("cae_vto")
  importeNeto      Decimal         @default(0) @db.Decimal(14, 2) @map("importe_neto")
  importeIVA       Decimal         @default(0) @db.Decimal(14, 2) @map("importe_iva")
  amount           Decimal         @db.Decimal(14, 2)
  environment      String          @default("test")
  metadata         Json            @default("{}")
  createdAt        DateTime        @default(now()) @map("created_at")

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  order   Order?   @relation(fields: [orderId], references: [id])
  payment Payment? @relation(fields: [paymentId], references: [id])

  @@unique([tenantId, tipoComprobante, puntoVenta, numero])
  @@index([tenantId, createdAt])
  @@map("fiscal_invoices")
}

// ─────────────────────────────────────────────────────────────────────────────
// MODULE: CRM — Clients & Suppliers
// ─────────────────────────────────────────────────────────────────────────────

model Client {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  name      String
  email     String?
  phone     String?
  address   String?
  notes     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, email])
  @@map("clients")
}

model Supplier {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  name        String
  contactName String?  @map("contact_name")
  email       String?
  phone       String?
  address     String?
  notes       String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("suppliers")
}

// ─────────────────────────────────────────────────────────────────────────────
// MODULE: CAJA DIGITAL — Cash register / ledger
// ─────────────────────────────────────────────────────────────────────────────

model CajaMovimiento {
  id          String    @id @default(uuid())
  tenantId    String    @map("tenant_id")
  tipo        CajaTipo
  monto       Decimal   @db.Decimal(14, 2)
  descripcion String
  categoria   String?
  metodoPago  String    @default("efectivo") @map("metodo_pago")
  notes       String?
  fecha       DateTime  @default(now())
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, fecha])
  @@map("caja_movimientos")
}

// ─────────────────────────────────────────────────────────────────────────────
// MODULE: SUBSCRIPTIONS — Cuarzo SaaS billing
// ─────────────────────────────────────────────────────────────────────────────

model SubscriptionPlan {
  id           String   @id @default(uuid())
  slug         String   @unique
  name         String
  priceUSD     Decimal  @db.Decimal(10, 2) @map("price_usd")
  intervalDays Int      @default(30) @map("interval_days")
  features     Json     @default("[]")
  active       Boolean  @default(true)
  mpPlanId     String?  @map("mp_plan_id")
  createdAt    DateTime @default(now()) @map("created_at")

  subscriptions Subscription[]

  @@map("subscription_plans")
}

model Subscription {
  id                 String             @id @default(uuid())
  tenantId           String             @unique @map("tenant_id")
  planId             String             @map("plan_id")
  status             SubscriptionStatus @default(pending)
  mpSubId            String?            @map("mp_sub_id")
  mpPayerId          String?            @map("mp_payer_id")
  mpCheckoutUrl      String?            @map("mp_checkout_url")
  currentPeriodStart DateTime?          @map("current_period_start")
  currentPeriodEnd   DateTime?          @map("current_period_end")
  cancelledAt        DateTime?          @map("cancelled_at")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  tenant Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan   SubscriptionPlan @relation(fields: [planId], references: [id])

  @@index([tenantId])
  @@map("subscriptions")
}

// ─────────────────────────────────────────────────────────────────────────────
// AUTH TOKENS — Password reset & email verification
// ─────────────────────────────────────────────────────────────────────────────

model PasswordResetToken {
  id        String    @id @default(uuid())
  email     String
  token     String    @unique
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([email])
  @@index([token])
  @@map("password_reset_tokens")
}

model EmailVerificationToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  token     String    @unique
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@index([token])
  @@map("email_verification_tokens")
}

// ─────────────────────────────────────────────────────────────────────────────
// AUDIT LOG — Append-only record of significant user actions
// ─────────────────────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(uuid())
  tenantId   String   @map("tenant_id")
  userId     String   @map("user_id")
  action     String
  resource   String
  resourceId String?  @map("resource_id")
  metadata   Json     @default("{}")
  ip         String?
  createdAt  DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([tenantId, resource])
  @@index([tenantId, userId])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────────────────────────────────────
// MODULE: TASKS — Corporate task management
// ─────────────────────────────────────────────────────────────────────────────

model Task {
  id          String       @id @default(uuid())
  tenantId    String       @map("tenant_id")
  title       String
  description String?
  status           TaskStatus     @default(pending)
  priority         TaskPriority   @default(medium)
  dueDate          DateTime?      @map("due_date")
  recurrence       TaskRecurrence @default(none)
  recurrenceConfig Json?          @map("recurrence_config")

  assignedToId String? @map("assigned_to_id")
  createdById  String  @map("created_by_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant     Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignedTo User?  @relation("TaskAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdBy  User   @relation("TaskCreator", fields: [createdById], references: [id])

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, dueDate])
  @@map("tasks")
}

// ─────────────────────────────────────────────────────────────────────────────
// PUSH SUBSCRIPTIONS — Web Push VAPID
// ─────────────────────────────────────────────────────────────────────────────

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  tenantId  String   @map("tenant_id")
  endpoint  String   @unique
  p256dh    String   @map("p256dh")
  auth      String
  createdAt DateTime @default(now()) @map("created_at")

  user   User   @relation(fields: [userId],   references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}
